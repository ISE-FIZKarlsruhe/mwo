###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001025
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001025> rdf:type owl:ObjectProperty ;
                                                      owl:inverseOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001028> ;
                                                      rdfs:domain obo:BFO_0000004 ;
                                                      rdfs:comment "inverse of property \"implemented by\"" ;
                                                      rdfs:label "implements"@en ;
                                                      skos:editorialNote "A shortcut for expressing the relation when 'independent continuant' is participant of some 'implementing process' which has output of 'NFDI resource'." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001028
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001028> rdf:type owl:ObjectProperty ;
                                                      rdfs:range obo:BFO_0000004 ;
                                                      rdfs:comment "The property relates an entity to an agent that has adapted or developed the entity for a specific purpose and actively uses it within a particular context." ;
                                                      rdfs:label "implemented by"@en ;
                                                      skos:editorialNote "A shortcut for expressing the relation when 'NFDI resource' is output of some 'implementing process' which has participant of  'independent continuant'." ,
                                                                         "The property was created on request of NFDI MatWerk community to support respond to competency questions like which tools are 'developed', 'co developed', or 'adopted' in' NFDI MatWerk consortium." .


