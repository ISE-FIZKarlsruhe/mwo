###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001000
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001000> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000018> ;
                                                      rdfs:label "expert discussion"@en ;
                                                      skos:definition "An event that involves a focused exchange of knowledge, opinions, and insights among specialists in a particular field to address complex topics, evaluate research findings, or explore emerging trends." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001001
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001001> rdf:type owl:Class ;
                                                      owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/pmd/co/PMD_0060009>
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty obo:IAO_0000219 ;
                                                                                                   owl:allValuesFrom <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000131>
                                                                                                 ]
                                                                                               ) ;
                                                                            rdf:type owl:Class
                                                                          ] ;
                                                      rdfs:subClassOf <https://w3id.org/pmd/co/PMD_0060009> ;
                                                      rdfs:label "event frequency datum"@en ;
                                                      skos:definition "Event frequency datum describes how often an events occurs within a given time interval" ;
                                                      skos:editorialNote "HBN: Concerning the content of ‘Events’ datasheet and its related knowledge graph, the ‘event frequency’ class was created to respond to competency questions like which frequency ab event take places?" ;
                                                      skos:example "annual, weekly, twice per year, 72 beats per minute, every four years" .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001002
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001002> rdf:type owl:Class ;
                                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                                            owl:oneOf ( <http://purls.helmholtz-metadaten.de/mwo/MWO_0001019>
                                                                                      )
                                                                          ] ;
                                                      rdfs:subClassOf <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000002> ;
                                                      rdfs:label "matwerk project"@en ;
                                                      skos:definition "A MatWerk project is a project within the NFDI MatWerk consortium that involves coordinated research, development, or infrastructure activities aimed at advancing materials science and engineering through data-driven methodologies and digitalization." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001003
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> rdf:type owl:Class ;
                                                      rdfs:subClassOf obo:BFO_0000015 ;
                                                      rdfs:label "collaboration"@en ;
                                                      skos:definition "A collaboration is a process in which multiple entities, such as individuals, organizations, or institutions, work together toward shared goals, contributing resources, expertise, or services to achieve mutual benefits." ;
                                                      skos:editorialNote "HBN: Concerning the content of ‘International Collaboration’ datasheet and its related knowledge graph, the ‘Collaboration’ class and its subclasses were created to defind the type of collaborations, and respond to competency questions like: what type of collaboration exists between organizations A and B, which agents are involved in collaboration C, which collaborations has agent D, etc." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001004
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001004> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "strategic collaboration"@en ;
                                                      skos:definition "Strategic Collaboration is a collaboration process in which multiple entities align their long-term objectives and resources to achieve significant mutual benefits in research, business, or policy initiatives." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001005
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001005> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "networking"@en ;
                                                      skos:definition "Networking is a collaboration process that involves building and maintaining professional, academic, or organizational relationships to exchange knowledge, expertise, or resources." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001006
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001006> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "project collaboration"@en ;
                                                      skos:definition "Project Collaboration is a collaboration process in which multiple entities contribute expertise, resources, and labor toward the successful completion of a specific project." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001007
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001007> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "joint efforting"@en ;
                                                      skos:definition "Joint Efforting is a collaboration process in which multiple entities combine efforts, knowledge, or labor toward a common goal, often in research, policy-making, or community initiatives." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001008
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001008> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "joint servicing"@en ;
                                                      skos:definition "Joint Servicing is a collaboration process in which two or more entities jointly provide or maintain a service, ensuring operational efficiency and shared responsibility." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001009
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001009> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "alliancing"@en ;
                                                      skos:definition "Alliancing is a collaboration process in which two or more entities form a long-term cooperative relationship based on shared objectives, often in research, industry, or government sectors." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001010
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001010> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001003> ;
                                                      rdfs:label "parenting"@en ;
                                                      skos:definition "Partnering is a collaboration process in which two or more entities form a structured partnership to achieve specific research, business, or development goals." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001012
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001012> rdf:type owl:Class ;
                                                      rdfs:subClassOf obo:IAO_0000027 ;
                                                      rdfs:label "date process ended"@en ;
                                                      skos:definition "The date and time at which the experimental process was completed." .


###  http://purls.helmholtz-metadaten.de/mwo/MWO_0001013
<http://purls.helmholtz-metadaten.de/mwo/MWO_0001013> rdf:type owl:Class ;
                                                      owl:equivalentClass [ owl:intersectionOf ( <http://purls.helmholtz-metadaten.de/mwo/MWO_0001204>
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty obo:IAO_0000219 ;
                                                                                                   owl:someValuesFrom obo:OBI_0000070
                                                                                                 ]
                                                                                               ) ;
                                                                            rdf:type owl:Class
                                                                          ] ;
                                                      rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001204> ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty obo:IAO_0000219 ;
                                                                        owl:someValuesFrom obo:OBI_0000070
                                                                      ] ;
                                                      rdfs:label "assay identifier"@en ;
