    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001219 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001219">
        <rdfs:label xml:lang="en">fair digital object</rdfs:label>
