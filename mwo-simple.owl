        <rdfs:label xml:lang="en">CSD identifier</rdfs:label>
        <skos:definition>CSD identifier is a crystallographic identifier that denotes an entry in the Cambridge Structural Database (CSD).</skos:definition>
    </owl:Class>
    


    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001215 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001215">
