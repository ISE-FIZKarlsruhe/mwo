    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001213 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001213">
        <rdfs:label xml:lang="en">crystallographic identifier</rdfs:label>
        <skos:definition>Crystallographic identifier is an identifier that denotes a crystallographic entity and is used to uniquely reference, distinguish, or track that entity within a crystallographic, materials science, or structural data context.</skos:definition>
    </owl:Class>
    


    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001214 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001214">
