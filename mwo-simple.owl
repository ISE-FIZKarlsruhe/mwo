    </owl:Class>
    


    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001220 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001220">
        <rdfs:label xml:lang="en">protocol</rdfs:label>
        <skos:definition>Protocol is a plan specification that prescribes the steps, conditions, rules, or procedures for carrying out a process, experiment, workflow, or activity.</skos:definition>
    </owl:Class>
    


    <!-- http://purls.helmholtz-metadaten.de/mwo/MWO_0001221 -->

    <owl:Class rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001221">
